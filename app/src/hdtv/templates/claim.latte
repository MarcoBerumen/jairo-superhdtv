<html>

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
        crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.2/css/all.min.css" />


</head>

<body>
    <div class="col-12 padding">
        <div class="card">
            <div class="card-header ">
                <div class="float-left text-right">
                    <h5 class="mb-0">Claim {$id}</h5>
                    Date: {$date}
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-6">
                        <h3 class="text-dark mb-1">{$store['name']}</h3>
                        <div> {$store['address']} </div>
                        <div>{$store['city']} </div>
                        <div>Email: {$store['email']}</div>
                        <div>Phone: {$store['telephone']}</div>
                    </div>
                    <div class="col-6 ">

                        <div>
                            <strong>Customer: [{$customer_id}]</strong> <br>
                            <i class='fa fa-user'></i> {$customer}
                        </div>
                        <div><i class='fa fa-location-arrow'></i> Address : {$address}</div>
                        <div><i class='fa fa-at'></i> Email: {$email}</div>
                        <div><i class='fa fa-mobile'></i> Phone: {$phone}</div>
                        <div><i class='fa fa-cash-register'></i> Payment Method: {$payment_method} {$contact|noescape}</<div>
                        </div>
                    </div>
                    <div class="table-responsive-sm">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th class="center">#</th>
                                    <th class="center">Grade</th>
                                    <th>Model</th>
                                    <th>Description</th>
                                    <th class="center">Qty</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                {foreach $items as $item}

                                <tr>
                                    <td class="center">1</td>
                                    <td class="center">{$item['grade']} </td>
                                    <td class="left strong">{$item['model']} </td>
                                    <td class="left">{$item['name']}</td>
                                    <td class="center">{$item['quantity']}</td>
                                    <td class="text-end">${$total}</td>
                                </tr>
                              
                                <tr>

                                    <td colspan="4" class="right">

                                      {if ($item['serial']??"" != "")}Serial Number : {$item['serial']}
                                      {/if}</td>
                                        <td class="center"></td>
                                    <td class="right"></td>
                                    <td class="text-end"></td>

                                </tr>
                                
                                {/foreach}
                            </tbody>
                        </table>
                    </div>
                    <div class="row">
                        <div class="col-6" style="vertical-align:top">



                        </div>
                        <div class="col-6 ml-auto">
                            <table class="table table-clear">
                                <tbody>



                                    <tr>
                                        <td class="left">
                                            <strong class="text-dark">Credit</strong>
                                        </td>
                                        <td class="text-end">
                                            <strong class="text-dark">$ {$total}</strong>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                {if $observation}


                <div class="card-footer bg-white">
                    <p class="mb-0">Observations : {$observation|noescape}</p>
                </div>
                {/if}
                </div>

                <div class="card-footer bg-white text-center">
                    <p class="mb-0">{$banner}</p>
                </div>
                
                                 
            </div>
        </div>

</body>
<script>
window.print();
</script>

</html>
